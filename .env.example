# Salesloft API key (required for live fetch; omit for mock/fallback mode)
SALESLOFT_API_KEY=your_salesloft_api_key_here

# OpenAI API key (required for extraction; omit in mock mode to use hardcoded results)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: file path for SQLite DB (default is in-memory, data lost on restart)
# DB_PATH=./data/pricing.db

# Optional: backend API URL (client uses this for all API/SSE requests; no proxy)
# Defaults to http://localhost:3001 if unset. Set in production to your server URL.
# VITE_API_ORIGIN=http://localhost:3001

# Optional: base URL for "View in Salesloft" links in the UI (client reads from .env in client dir or root)
# VITE_SALESLOFT_APP_CALLS_BASE=https://app.salesloft.com/app/calls
